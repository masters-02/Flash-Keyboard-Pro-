<?xml version="1.0" encoding="utf-8"?>
<!--
  btn_keyboard_key_neon_normal.xml
  Normal (idle) state for a Flash Keyboard Pro key.
  Produces a deep-black rounded rectangle with a neon-pink border.
  The "glow" is approximated by layering a slightly-blurred larger
  stroke behind the solid border using a layer-list.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Layer 1 – outer glow ring (semi-transparent, slightly larger) -->
    <item
        android:left="0dp"
        android:top="0dp"
        android:right="0dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <stroke
                android:width="3dp"
                android:color="#55FF007F" />
            <corners android:radius="@dimen/button_corner_radius_neon" />
        </shape>
    </item>

    <!-- Layer 2 – crisp neon-pink border + key face fill -->
    <item
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/neon_black_secondary" />
            <stroke
                android:width="@dimen/neon_border_width"
                android:color="@color/neon_pink" />
            <corners android:radius="@dimen/button_corner_radius_neon" />
        </shape>
    </item>

</layer-list>
