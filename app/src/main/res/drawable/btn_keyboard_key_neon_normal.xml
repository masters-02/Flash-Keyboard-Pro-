<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#00000000"/>
            <stroke android:width="3dp" android:color="#55FF007F"/>
            <corners android:radius="@dimen/button_corner_radius_neon"/>
        </shape>
    </item>
    <item android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/neon_black_secondary"/>
            <stroke android:width="1dp" android:color="@color/neon_pink"/>
            <corners android:radius="@dimen/button_corner_radius_neon"/>
        </shape>
    </item>
</layer-list>
