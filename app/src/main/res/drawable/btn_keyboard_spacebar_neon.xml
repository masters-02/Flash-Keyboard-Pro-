<?xml version="1.0" encoding="utf-8"?>
<!--
  btn_keyboard_spacebar_neon.xml
  Spacebar drawable for the neon theme — a wider pill shape with neon-pink border.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_pressed="true">
        <layer-list>
            <item android:left="0dp" android:top="0dp" android:right="0dp" android:bottom="0dp">
                <shape android:shape="rectangle">
                    <solid android:color="#00000000"/>
                    <stroke android:width="4dp" android:color="#AAFF007F"/>
                    <corners android:radius="20dp"/>
                </shape>
            </item>
            <item android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="2dp">
                <shape android:shape="rectangle">
                    <solid android:color="@color/neon_key_bg_pressed"/>
                    <stroke android:width="2dp" android:color="@color/neon_pink"/>
                    <corners android:radius="18dp"/>
                </shape>
            </item>
        </layer-list>
    </item>

    <item>
        <layer-list>
            <item android:left="0dp" android:top="0dp" android:right="0dp" android:bottom="0dp">
                <shape android:shape="rectangle">
                    <solid android:color="#00000000"/>
                    <stroke android:width="3dp" android:color="#55FF007F"/>
                    <corners android:radius="20dp"/>
                </shape>
            </item>
            <item android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="2dp">
                <shape android:shape="rectangle">
                    <solid android:color="@color/neon_spacebar_bg"/>
                    <stroke android:width="1dp" android:color="@color/neon_pink"/>
                    <corners android:radius="18dp"/>
                </shape>
            </item>
        </layer-list>
    </item>

</selector>
