<?xml version="1.0" encoding="utf-8"?>
<!--
  btn_keyboard_key_neon_pressed.xml
  Pressed state for a Flash Keyboard Pro key.
  Fills the key with a translucent neon-pink and intensifies the glow ring.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Layer 1 – intensified outer glow ring -->
    <item
        android:left="0dp"
        android:top="0dp"
        android:right="0dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <stroke
                android:width="4dp"
                android:color="#AAFF007F" />
            <corners android:radius="@dimen/button_corner_radius_neon" />
        </shape>
    </item>

    <!-- Layer 2 – key face with neon-pink fill + bright border -->
    <item
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/neon_key_bg_pressed" />
            <stroke
                android:width="2dp"
                android:color="@color/neon_pink" />
            <corners android:radius="@dimen/button_corner_radius_neon" />
        </shape>
    </item>

</layer-list>
