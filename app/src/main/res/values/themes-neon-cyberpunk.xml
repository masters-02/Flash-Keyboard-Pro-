<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:android="http://schemas.android.com/apk/res/android">

    <style name="KeyboardTheme.NeonCyberpunk">
        <item name="inputViewStyle">@style/InputView</item>
        <item name="keyboardStyle">@style/Keyboard.NeonCyberpunk</item>
        <item name="keyboardViewStyle">@style/KeyboardView.NeonCyberpunk</item>
        <item name="mainKeyboardViewStyle">@style/MainKeyboardView.NeonCyberpunk</item>
        <item name="moreKeysKeyboardStyle">@style/MoreKeysKeyboard.NeonCyberpunk</item>
        <item name="moreKeysKeyboardViewStyle">@style/MoreKeysKeyboardView.NeonCyberpunk</item>
        <item name="functionalTextColor">@color/neon_pink</item>
        <item name="popupPanelBackgroundColor">@color/neon_black_secondary</item>
        <item name="keyPressedBackgroundColor">@color/neon_key_bg_pressed</item>
        <item name="keyNormalBackgroundColor">@color/neon_key_bg_normal</item>
    </style>

    <style name="Keyboard.NeonCyberpunk" parent="Keyboard">
        <item name="horizontalGap">2%p</item>
        <item name="verticalGap">2%p</item>
    </style>

    <style name="KeyboardView.NeonCyberpunk" parent="KeyboardView">
        <item name="android:background">@color/neon_black</item>
        <item name="keyBackground">@drawable/btn_keyboard_key_neon</item>
        <item name="functionalKeyBackground">@drawable/btn_keyboard_key_neon</item>
        <item name="spacebarBackground">@drawable/btn_keyboard_spacebar_neon</item>
        <item name="keyTextColor">@color/neon_key_text</item>
        <item name="keyTextInactivatedColor">@color/neon_pink_dim</item>
        <item name="keyHintLetterColor">@color/neon_pink_dim</item>
        <item name="keyHintLabelColor">@color/neon_key_text_hint</item>
        <item name="keyShiftedLetterHintInactivatedColor">@color/neon_pink_dim</item>
        <item name="keyShiftedLetterHintActivatedColor">@color/neon_pink</item>
        <item name="keyPreviewTextColor">@color/neon_pink</item>
    </style>

    <style name="MainKeyboardView.NeonCyberpunk" parent="KeyboardView.NeonCyberpunk">
        <item name="keyPreviewBackground">@drawable/keyboard_key_feedback_background</item>
        <item name="keyPreviewHeight">@dimen/config_key_preview_height_lxx</item>
        <item name="keyPreviewWidth">@dimen/config_key_preview_width_lxx</item>
        <item name="keyPreviewOffset">@dimen/config_key_preview_offset_lxx</item>
        <item name="keyPreviewDismissAnimator">@anim/key_preview_dismiss_lxx</item>
        <item name="languageOnSpacebarTextColor">@color/neon_pink_dim</item>
    </style>

    <style name="MoreKeysKeyboard.NeonCyberpunk" parent="Keyboard.NeonCyberpunk">
        <item name="keyboardTopPadding">0%p</item>
        <item name="keyboardBottomPadding">0%p</item>
        <item name="horizontalGap">0%p</item>
    </style>

    <style name="MoreKeysKeyboardView.NeonCyberpunk" parent="KeyboardView.NeonCyberpunk">
        <item name="android:background">@drawable/keyboard_popup_panel_background</item>
        <item name="keyBackground">@drawable/btn_keyboard_key_popup</item>
        <item name="keyTypeface">normal</item>
        <item name="verticalCorrection">@dimen/config_more_keys_keyboard_vertical_correction</item>
    </style>

</resources>
